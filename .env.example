# Runtime mode
# local_stub = deterministic scripted model, no external services required
# llm = use a real model gateway implementation
AGENT_RUNTIME_MODE=local_stub

# LLM provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Default model routing
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Tool and retrieval backends
DATABASE_URL=
REDIS_URL=
VECTOR_DATABASE_URL=
SEARCH_API_KEY=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
TRACE_SAMPLE_RATE=1.0

# Safety and cost controls
MAX_AGENT_STEPS=5
MAX_REQUEST_COST_USD=0.25
ENABLE_HUMAN_APPROVAL=false

